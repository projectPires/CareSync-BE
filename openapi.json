        "summary": "Registar recusa → refused. reason obrigatório (422 se vazio).",
        "tags": [
          "emar"
        ]
      }
    },
    "/api/residents/{residentId}/vitals": {
      "post": {
        "operationId": "VitalsController_create",
        "parameters": [
          {
            "name": "residentId",
            "required": true,
            "in": "path",
            "schema": {
              "type": "string"
            }
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/CreateVitalDto"
              }
            }
          }
        },
        "responses": {
          "201": {
            "description": ""
          },
          "403": {
            "description": "Métrica avançada sem permissão delegada"
          },
          "404": {
            "description": "Residente fora do âmbito"
          },
          "422": {
            "description": "Valor inválido para a métrica / correção sem reason"
          }
        },
        "security": [
          {
            "bearer": []
          }
        ],
        "summary": "Registar sinal vital. SpO₂/Glicemia/Dor exigem vitals.record_advanced (🔒 delegável a aide). abnormal calculado no servidor.",
        "tags": [
          "vitals"
        ]
      },
      "get": {
        "operationId": "VitalsController_history",
        "parameters": [
          {
            "name": "residentId",
            "required": true,
            "in": "path",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "metric",
            "required": false,
            "in": "query",
            "schema": {
              "enum": [
                "bp",
                "hr",
                "spo2",
                "temp",
                "glucose",
                "pain"
              ],
              "type": "string"
            }
          },
          {
            "name": "from",
            "required": false,
            "in": "query",
            "description": "ISO 8601 (default: -7 dias)",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "to",
            "required": false,
            "in": "query",
            "description": "ISO 8601 (default: agora)",
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": ""
          }
        },
        "security": [
          {
            "bearer": []
          }
        ],
        "summary": "Histórico de sinais vitais (estado atual). Auxiliar limitado a 24h (server-side).",
        "tags": [
          "vitals"
        ]
      }
    }
  },
  "info": {
    "title": "CareSync API",
    "description": "Backend for CareSync — clinical management of Portuguese ERPI. Multi-tenant (RLS by lar_id), offline-first sync, append-only clinical data.",
    "version": "1.0",
    "contact": {}
  },
  "tags": [],
  "servers": [],
  "components": {
    "securitySchemes": {
      "bearer": {
        "scheme": "bearer",
        "bearerFormat": "JWT",
        "type": "http"
      }
    },
    "schemas": {
      "LoginDto": {
        "type": "object",
        "properties": {
          "email": {
            "type": "string",
            "example": "helena@larbemestar.pt"
          },
          "password": {
            "type": "string",
            "example": "demo-admin-123"
          },
          "lar_id": {
            "type": "string",
            "description": "Desambiguação quando o mesmo email existe em mais do que um Lar"
          }
        },
        "required": [
          "email",
          "password"
        ]
      },
      "TokenPairResponse": {
        "type": "object",
        "properties": {
          "access_token": {
            "type": "string"
          },
          "refresh_token": {
            "type": "string",
            "description": "Opaco; rotativo — cada refresh devolve um novo"
          },
          "user": {
            "type": "object",
            "example": {
              "id": "uuid",
              "lar_id": "uuid",
              "name": "Sofia",
              "role": "nurse",
              "floors": [
                2
              ],
              "extra_permissions": []
            }
          }
        },
        "required": [
          "access_token",
          "refresh_token",
          "user"
        ]
      },
      "PinLoginDto": {
        "type": "object",
        "properties": {
          "email": {
            "type": "string"
          },
          "pin": {
            "type": "string",
            "description": "PIN de 4–6 dígitos",
            "example": "1234"
          },
          "lar_id": {
            "type": "string"
          }
        },
        "required": [
          "email",
          "pin"
        ]
      },
      "SetPinDto": {
        "type": "object",
        "properties": {
          "pin": {
            "type": "string",
            "description": "PIN de 4–6 dígitos"
          }
        },
        "required": [
          "pin"
        ]
      },
      "RefreshDto": {
        "type": "object",
        "properties": {
          "refresh_token": {
            "type": "string",
            "description": "Refresh token opaco recebido no login (formato \"<id>.<segredo>\")",
            "example": "8df11de1-a3aa-4aa9-b423-8038729b0153.kQ3xJ9mP2vL8nR5tW7yB4cF6hD1gS0aZ"
          }
        },
        "required": [
          "refresh_token"
        ]
      },
      "InviteDto": {
        "type": "object",
        "properties": {
          "email": {
            "type": "string"
          },
          "name": {
            "type": "string"
          },
          "role": {
            "type": "string",
            "enum": [
              "nurse",
              "aide",
              "doctor"
            ]
          },
          "floors": {
            "description": "Pisos atribuídos",
            "type": "array",
            "items": {
              "type": "number"
            }
          },
          "licence_number": {
            "type": "string",
            "description": "Cédula profissional (obrigatória para nurse/doctor)"
          }
        },
        "required": [
          "email",
          "name",
          "role",
          "floors"
        ]
      },
      "AcceptInviteDto": {
        "type": "object",
        "properties": {
          "token": {
            "type": "string",
            "description": "Token do email de convite (formato \"<id>.<segredo>\")",
            "example": "3f2a1b00-9c8d-4e7f-a6b5-c4d3e2f1a0b9.mN8xK2pQ7vR4tY6wB3cZ"
          },
          "password": {
            "type": "string",
            "example": "a-minha-password-segura"
          }
        },
        "required": [
          "token",
          "password"
        ]
      },
      "ResendInviteDto": {
        "type": "object",
        "properties": {
          "email": {
            "type": "string"
          }
        },
        "required": [
          "email"
        ]
      },
      "UpdateLarDto": {
        "type": "object",
        "properties": {
          "name": {
            "type": "string",
            "example": "Lar Bem-Estar"
          },
          "legal_name": {
            "type": "string"
          },
          "address": {
            "type": "object",
            "example": {
              "street": "Rua das Flores 12",
              "postal": "1200-192",
              "city": "Lisboa"
            }
          },
          "floors": {
            "type": "number",
            "description": "Número de pisos clínicos"
          },
          "capacity": {
            "type": "number",
            "description": "Capacidade total (camas)"
          },
          "config": {
            "type": "object",
            "description": "Rácios mínimos, horários de turnos padrão, etc."
          }
        }
      },
      "UpdateUserDto": {
        "type": "object",
        "properties": {
          "name": {
            "type": "string"
          },
          "role": {
            "type": "string",
            "enum": [
              "nurse",
              "aide",
              "doctor"
            ]
          },
          "floors": {
            "description": "Pisos atribuídos",
            "type": "array",
            "items": {
              "type": "number"
            }
          },
          "licence_number": {
            "type": "string",
            "description": "Cédula profissional (obrigatória para nurse/doctor)"
          }
        }
      },
      "CreateResidentDto": {
        "type": "object",
        "properties": {
          "name": {
            "type": "string",
            "example": "Manuel Sousa"
          },
          "date_of_birth": {
            "type": "string",
            "example": "1940-05-15"
          },
          "gender": {
            "type": "string",
            "enum": [
              "f",
              "m",
              "nb",
              "not_disclosed"
            ]
          },
          "sns_number": {
            "type": "string",
            "description": "Número SNS — único por Lar",
            "example": "111222333"
          },
          "nif": {
            "type": "string"
          },
          "room": {
            "type": "string",
            "example": "101"
          },
          "floor": {
            "type": "number",
            "example": 1
          },
          "blood_type": {
            "type": "string",
            "enum": [
              "a_pos",
              "a_neg",
              "b_pos",
              "b_neg",
              "ab_pos",
              "ab_neg",
              "o_pos",
              "o_neg",
              "unknown"
            ],
            "default": "unknown"
          },
          "allergies": {
            "example": [
              "Penicilina"
            ],
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "chronic_conditions": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "admitted_at": {
            "type": "string",
            "example": "2026-01-10"
          },
          "emergency_contact": {
            "type": "object",
            "example": {
              "name": "Maria Sousa",
              "relation": "filha",
              "phone": "+351 910 000 000"
            }
          },
          "assistant_doctor": {
            "type": "object",
            "example": {
              "name": "Dr. Luís",
              "licence": "12345",
              "phone": "+351 210 000 000"
            }
          },
          "rgpd_consent": {
            "type": "boolean",
            "description": "Consentimento RGPD assinado",
            "default": false
          },
          "rgpd_consent_at": {
            "type": "string",
            "example": "2026-01-10"
          }
        },
        "required": [
          "name",
          "date_of_birth",
          "gender",
          "sns_number",
          "room",
          "floor",
          "admitted_at",
          "emergency_contact"
        ]
      },
      "UpdateResidentAdminDto": {
        "type": "object",
        "properties": {
          "name": {
            "type": "string"
          },
          "sns_number": {
            "type": "string"
          },
          "nif": {
            "type": "string"
          },
          "room": {
            "type": "string"
          },
          "floor": {
            "type": "number"
          },
          "emergency_contact": {
            "type": "object"
          },
          "assistant_doctor": {
            "type": "object"
          },
          "rgpd_consent": {
            "type": "boolean"
          },
          "rgpd_consent_at": {
            "type": "string"
          }
        }
      },
      "UpdateResidentClinicalDto": {
        "type": "object",
        "properties": {
          "allergies": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "chronic_conditions": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "blood_type": {
            "type": "string",
            "enum": [
              "a_pos",
              "a_neg",
              "b_pos",
              "b_neg",
              "ab_pos",
              "ab_neg",
              "o_pos",
              "o_neg",
              "unknown"
            ]
          },
          "status": {
            "type": "string",
            "enum": [
              "estavel",
              "atencao",
              "critico",
              "recuperacao"
            ],
            "description": "Estado clínico"
          }
        }
      },
      "UpdateDnrDto": {
        "type": "object",
        "properties": {
          "dnr": {
            "type": "boolean",
            "description": "Diretiva DNR ativa"
          },
          "dnr_document_url": {
            "type": "string",
            "description": "PDF da diretiva assinada"
          }
        },
        "required": [
          "dnr"
        ]
      },
      "ArchiveResidentDto": {
        "type": "object",
        "properties": {
          "reason": {
            "type": "string",
            "enum": [
              "death",
              "discharge",
              "transfer",
              "other"
            ]
          }
        },
        "required": [
          "reason"
        ]
      },
      "MedicationScheduleDto": {
        "type": "object",
        "properties": {
          "times": {
            "example": [
              "08:00",
              "20:00"
            ],
            "description": "Horas HH:MM (24h), fuso do Lar. Vazio = SOS/PRN (sem materialização).",
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "daysOfWeek": {
            "example": [
              1,
              2,
              3,
              4,
              5
            ],
            "description": "Dias da semana ISO 1=Seg..7=Dom. Omitido = todos os dias.",
            "type": "array",
            "items": {
              "type": "number"
            }
          }
        }
      },
      "CreateMedicationDto": {
        "type": "object",
        "properties": {
          "drug": {
            "type": "string",
            "example": "Lisinopril"
          },
          "dci": {
            "type": "string",
            "description": "Denominação Comum Internacional",
            "example": "lisinopril"
          },
          "dose": {
            "type": "string",
            "example": "10 mg"
          },
          "form": {
            "type": "string",
            "enum": [
              "comp",
              "cap",
              "drop",
              "patch",
              "inj",
              "suspension"
            ]
          },
          "route": {
            "type": "string",
            "enum": [
              "oral",
              "sublingual",
              "im",
              "sc",
              "iv",
              "topical"
            ]
          },
          "schedule": {
            "$ref": "#/components/schemas/MedicationScheduleDto"
          },
          "condition": {
            "type": "string",
            "example": "Em jejum"
          },
          "prescribed_by": {
            "type": "string",
            "description": "Médico prescritor (default: utilizador atual)"
          },
          "start_date": {
            "type": "string",
            "example": "2026-06-15"
          },
          "end_date": {
            "type": "string",
            "example": "2026-12-31",
            "description": "Omitido = crónico"
          }
        },
        "required": [
          "drug",
          "dose",
          "form",
          "route",
          "schedule",
          "start_date"
        ]
      },
      "UpdateMedicationDto": {
        "type": "object",
        "properties": {
          "drug": {
            "type": "string"
          },
          "dci": {
            "type": "string"
          },
          "dose": {
            "type": "string"
          },
          "form": {
            "type": "string",
            "enum": [
              "comp",
              "cap",
              "drop",
              "patch",
              "inj",
              "suspension"
            ]
          },
          "route": {
            "type": "string",
            "enum": [
              "oral",
              "sublingual",
              "im",
              "sc",
              "iv",
              "topical"
            ]
          },
          "schedule": {
            "$ref": "#/components/schemas/MedicationScheduleDto"
          },
          "condition": {
            "type": "string"
          },
          "end_date": {
            "type": "string"
          }
        }
      },
      "DiscontinueMedicationDto": {
        "type": "object",
        "properties": {
          "reason": {
            "type": "string",
            "description": "Motivo da descontinuação (audit)"
          }
        }
      },
      "ConfirmAdministrationDto": {
        "type": "object",
        "properties": {
          "notes": {
            "type": "string",
            "description": "Nota opcional da administração"
          }
        }
      },
      "RefuseAdministrationDto": {
        "type": "object",
        "properties": {
          "reason": {
            "type": "string",
            "description": "Motivo da recusa — obrigatório (validado no serviço → 422 se vazio)",
            "example": "Residente recusou"
          },
          "notes": {
            "type": "string"
          }
        },
        "required": [
          "reason"
        ]
      },
      "CreateVitalDto": {
        "type": "object",
        "properties": {
          "metric": {
            "type": "string",
            "enum": [
              "bp",
              "hr",
              "spo2",
              "temp",
              "glucose",
              "pain"
            ]
          },
          "value": {
            "type": "object",
            "description": "Valor por métrica: bp = {sys,dia}; restantes = {value}. Validado por métrica.",
            "example": {
              "sys": 128,
              "dia": 82
            }
          },
          "recorded_at": {
            "type": "string",
            "description": "Instante da medição (default: agora)"
          },
          "notes": {
            "type": "string"
          },
          "client_id": {
            "type": "string",
            "description": "UUID gerado no dispositivo — idempotência do sync offline"
          },
          "supersedes_id": {
            "type": "string",
            "description": "Correção: id da leitura a substituir (append-only)"
          },
          "reason": {
            "type": "string",
            "description": "Motivo da correção — obrigatório se supersedes_id (422 se vazio)"
          }
        },
        "required": [
          "metric",
          "value"
        ]
      }
    }
  }
}
