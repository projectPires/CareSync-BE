# All values below match docker-compose defaults — copy to .env and go.
# In production every value is required explicitly (no defaults accepted).

NODE_ENV=development
PORT=3000

# Postgres 16 (docker-compose service: postgres)
DATABASE_URL=postgresql://caresync:caresync@localhost:5432/caresync

# Redis 7 (docker-compose service: redis)
REDIS_URL=redis://localhost:6379

# S3-compatible storage (docker-compose service: minio)
S3_ENDPOINT=http://localhost:9000
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=minioadmin
S3_BUCKET=caresync
S3_REGION=eu-central-1
