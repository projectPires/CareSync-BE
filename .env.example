# All values below match docker-compose defaults — copy to .env and go.
# In production every value is required explicitly (no defaults accepted).

NODE_ENV=development
PORT=3000

# Postgres 16 (docker-compose service: postgres)
# App role — NOSUPERUSER + NOBYPASSRLS (superuser would bypass row-level security)
DATABASE_URL=postgresql://caresync_app:caresync_app@localhost:5432/caresync
# Owner role — used ONLY by prisma migrate
MIGRATION_DATABASE_URL=postgresql://caresync:caresync@localhost:5432/caresync

# Redis 7 (docker-compose service: redis)
REDIS_URL=redis://localhost:6379

# S3-compatible storage (docker-compose service: minio)
S3_ENDPOINT=http://localhost:9000
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=minioadmin
S3_BUCKET=caresync
S3_REGION=eu-central-1

# Auth — JWT 15 min + refresh rotativo 30 d. Em produção o JWT_SECRET é
# obrigatório (mín. 16 chars; o default de dev é recusado).
JWT_SECRET=dev-only-jwt-secret-change-me
JWT_ACCESS_TTL_SEC=900
JWT_REFRESH_TTL_DAYS=30
